{
  "name": "luatools",
  "version": "107.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "pnpm run build:millennium && pnpm run build:zip",
    "build:millennium": "millennium-ttc --build prod && node scripts/build-plugin.mjs",
    "build:zip": "node scripts/build-plugin.mjs --zip",
    "dev": "millennium-ttc --build dev"
  },
  "devDependencies": {
    "@steambrew/api": "^5.8.4",
    "@steambrew/client": "^5.8.5",
    "@steambrew/ttc": "^3.3.6",
    "@steambrew/webkit": "^5.8.4",
    "prettier": "^3.8.2"
  }
}
